<div class="flex-shrink-0" style="background: transparent;">
    <a href="{{ routes.root_url }}" class="flex items-center">
        <img
            class="h-10 w-auto object-contain"
            src="{{ 'loopzo_light_logo.png' | asset_url }}"
            alt="{{ shop.name }} Logo"
            width="200" 
            height="80"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            style="background-color: transparent !important; display: block; border: none;">
    </a>
</div>


<div class="hidden md:flex md:items-center md:space-x-8">
    <a href="/" class="text-white font-bold text-sm hover:text-slate-200 transition">Home</a>

    {% render 'header-dropdown-menu' %}

    <a href="#features" class="text-white font-bold text-sm hover:text-slate-200 transition">Customer experiences</a>
    <a href="/blogs/news" class="text-white font-bold text-sm hover:text-slate-200 transition">News</a>

    <!-- Language Switcher Dropdown (Desktop) -->
    <div id="language-switcher-container" class="relative inline-block text-left hidden md:block ml-8" style="z-index: 40;">
        <button id="lang-dropdown-btn" onclick="toggleLanguageDropdown()" type="button" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-bold text-white hover:bg-slate-700 transition duration-300 focus:outline-none" aria-expanded="false" aria-haspopup="true">
            <span id="active-lang-flag">🇳🇱</span>
            <span id="active-lang-name">Dutch</span>
            <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
        </button>

        <!-- Dropdown Menu -->
        <div id="lang-dropdown-menu" class="hidden absolute right-0 mt-2 w-36 rounded-lg bg-white shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none z-50">
            <div class="py-1" role="none">
                <a href="javascript:switchLanguage('nl')" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-slate-100 hover:text-slate-900 transition font-medium" role="menuitem" id="dropdown-lang-nl">
                    <span style="font-size: 16px;">🇳🇱</span>
                    <span>Dutch</span>
                </a>
                <a href="javascript:switchLanguage('de')" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-700 hover:bg-slate-100 hover:text-slate-900 transition font-medium" role="menuitem" id="dropdown-lang-de">
                    <span style="font-size: 16px;">🇩🇪</span>
                    <span>Deutsch</span>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="md:hidden flex items-center gap-3">
    <!-- Mobile Language Switcher Dropdown -->
    <div id="mobile-language-switcher-container" class="relative inline-block text-left" style="z-index: 40;">
        <button id="mobile-lang-dropdown-btn" onclick="toggleMobileLanguageDropdown()" type="button" class="flex items-center gap-1.5 px-2 py-1.5 rounded-lg text-sm font-bold text-white hover:bg-slate-700 transition duration-300 focus:outline-none" aria-expanded="false" aria-haspopup="true">
            <span id="mobile-active-lang-flag">🇳🇱</span>
            <span class="text-xs uppercase font-extrabold tracking-wider" id="mobile-active-lang-code">NL</span>
            <svg class="w-3 h-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
        </button>

        <!-- Dropdown Menu -->
        <div id="mobile-lang-dropdown-menu" class="hidden absolute right-0 mt-2 w-28 rounded-lg bg-white shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none z-50">
            <div class="py-1" role="none">
                <a href="javascript:switchLanguage('nl')" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-slate-100 hover:text-slate-900 transition font-medium" role="menuitem" id="mobile-dropdown-lang-nl">
                    <span style="font-size: 14px;">🇳🇱</span>
                    <span>NL</span>
                </a>
                <a href="javascript:switchLanguage('de')" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-slate-100 hover:text-slate-900 transition font-medium" role="menuitem" id="mobile-dropdown-lang-de">
                    <span style="font-size: 14px;">🇩🇪</span>
                    <span>DE</span>
                </a>
            </div>
        </div>
    </div>

    <button id="mobile-menu-button" onclick="toggleMenu()" type="button"
        class="text-white hover:text-slate-300 focus:outline-none" aria-controls="mobile-menu"
        aria-expanded="false">
        <span class="sr-only">Open main menu</span>
        <svg class="h-6 w-6" stroke="currentColor" fill="none" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
    </button>
</div>
