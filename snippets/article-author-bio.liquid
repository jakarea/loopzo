 {%- comment -%}
  Snippet: Author Bio Box
  Source: Metaobject (custom.related_author)
  Design: Loopzo Style (Circular Image + Bio)
{%- endcomment -%}

{%- assign author = article.metafields.custom.related_author.value -%}

{%- if author != blank -%}
  <!-- Author Info -->
  <div class="flex items-start gap-4 border-t border-slate-200 pt-8">
      {%- if author.photo != blank -%}
          <div class="w-16 h-16 rounded-full overflow-hidden flex-shrink-0 bg-slate-200">
              <img src="{{ author.photo | image_url: width: 150, height: 150, crop: 'center' }}"
                   alt="{{ author.name }}"
                   class="w-full h-full object-cover"
                   loading="lazy"
                   width="64"
                   height="64">
          </div>
      {%- else -%}
          <div class="w-16 h-16 rounded-full overflow-hidden flex-shrink-0 bg-slate-200">
              <img src="https://ui-avatars.com/api/?name={{ author.name | url_encode }}&size=150&background=334155&color=fff"
                   alt="{{ author.name }}"
                   class="w-full h-full object-cover"
                   loading="lazy"
                   width="64"
                   height="64">
          </div>
      {%- endif -%}
      
      <div class="flex-1">
          <h3 class="text-slate-900 font-bold text-base mb-1">
              {{ author.name }}
              {%- if author.job_title != blank -%}
                  <span class="font-normal text-slate-600">({{ author.job_title }})</span>
              {%- endif -%}
          </h3>
          <div class="text-slate-600 text-sm leading-relaxed">
              {{ author.bio | metafield_tag }}
          </div>
      </div>
  </div>
{%- endif -%}