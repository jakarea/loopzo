<!-- Skip Link for Keyboard Users -->
<a
  href="#contact-form"
  class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-slate-900 focus:text-white focus:px-4 focus:py-2 focus:rounded-md focus:shadow-lg"
>
  Spring naar contactformulier
</a>

<!-- Main Container -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20">

  <!-- ========== 1. HERO / INTRO SECTION ========== -->
  <section aria-labelledby="contact-heading" class="mb-12 sm:mb-16">
    <div style="display:grid;grid-template-columns:1fr;gap:2rem;" class="lg:grid-cols-2 lg:gap-12">

      <!-- Left: Text Content -->
      <div>
        <h1 id="contact-heading" style="font-size:2rem;line-height:1.2;font-weight:700;color:#0f172a;margin-bottom:1.5rem;" class="sm:text-4xl lg:text-5xl">
          Neem contact op met Loopzo
        </h1>

        <p style="font-size:1rem;color:#334155;line-height:1.7;margin-bottom:1rem;">
          Heb je een vraag over je bestelling, garantie of levering? We staan voor je klaar en helpen je graag verder &mdash; via telefoon, e-mail of het contactformulier hieronder.
        </p>

        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:2rem;">
          <svg style="width:1.125rem;height:1.125rem;color:#10b981;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span style="font-size:0.875rem;color:#475569;font-weight:500;">We reageren meestal binnen 1 werkdag</span>
        </div>

        <!-- Visit by Appointment -->
        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.75rem;padding:1.25rem;">
          <h2 style="font-size:1.125rem;font-weight:700;color:#0f172a;margin-bottom:0.5rem;">Bezoek op afspraak</h2>
          <p style="font-size:0.9375rem;color:#475569;line-height:1.6;margin:0;">
            Wij ontvangen klanten graag op afspraak, zodat we alle tijd hebben om alles rustig uit te leggen. Buiten openingstijden is vaak ook mogelijk &mdash; neem gerust contact op.
          </p>
        </div>
      </div>

      <!-- Right: Contact Options (Compact Row) -->
      <div style="display:flex;flex-direction:column;justify-content:center;gap:1.5rem;">
        <a href="tel:0182239021" style="display:flex;align-items:center;gap:0.75rem;text-decoration:none;">
          <div style="width:2.25rem;height:2.25rem;border-radius:0.375rem;background:#f1f5f9;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg style="width:1rem;height:1rem;color:#334155;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <p style="font-size:0.6875rem;color:#64748b;font-weight:500;margin:0;">Direct bereikbaar</p>
            <p style="font-size:1rem;font-weight:700;color:#0f172a;margin:0;">0182 239 021</p>
          </div>
        </a>

        <a href="mailto:info@loopzo.nl" style="display:flex;align-items:center;gap:0.75rem;text-decoration:none;">
          <div style="width:2.25rem;height:2.25rem;border-radius:0.375rem;background:#f1f5f9;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg style="width:1rem;height:1rem;color:#334155;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p style="font-size:0.6875rem;color:#64748b;font-weight:500;margin:0;">E-mail</p>
            <p style="font-size:1rem;font-weight:700;color:#0f172a;margin:0;">info@loopzo.nl</p>
          </div>
        </a>

        <a href="https://maps.google.com/?q=Loopzo+Moordrecht" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:0.75rem;text-decoration:none;">
          <div style="width:2.25rem;height:2.25rem;border-radius:0.375rem;background:#f1f5f9;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg style="width:1rem;height:1rem;color:#334155;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <p style="font-size:0.6875rem;color:#64748b;font-weight:500;margin:0;">Locatie</p>
            <p style="font-size:1rem;font-weight:600;color:#0f172a;margin:0;">Zuidbaan 548H, 2841MD Moordrecht</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== 2. CONTACT FORM SECTION ========== -->
  <section
    id="contact-form"
    aria-labelledby="contact-form-heading"
    style="background:linear-gradient(to br,#f8fafc,#fff);padding:3rem 0;margin-bottom:4rem;"
    class="sm:py-16 lg:py-20"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2
        id="contact-form-heading"
        style="font-size:1.75rem;font-weight:700;color:#0f172a;text-align:center;margin-bottom:0.5rem;"
        class="sm:text-3xl lg:text-4xl"
      >
        Stuur ons een bericht
      </h2>
      <p style="font-size:0.9375rem;color:#64748b;text-align:center;margin-bottom:2.5rem;">
        Vul het formulier in en we nemen zo snel mogelijk contact met je op.
      </p>

      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div style="background:#f0fdf4;border:1px solid #bbf7d0;color:#166534;padding:1rem;border-radius:0.5rem;margin-bottom:1.5rem;">
            Bedankt voor je bericht! We nemen zo snel mogelijk contact met je op.
          </div>
        {% endif %}

        {% if form.errors %}
          <div style="background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:1rem;border-radius:0.5rem;margin-bottom:1.5rem;">
            <p style="font-weight:600;margin:0 0 0.5rem;">Er zijn enkele problemen met je inzending:</p>
            <ul style="list-style:disc;padding-left:1.25rem;margin:0;">
              {% for field in form.errors %}
                <li>{{ field }} - {{ form.errors.messages[field] }}</li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        <div style="display:flex;flex-direction:column;gap:1rem;">
          <!-- Name & Email Row -->
          <div style="display:grid;grid-template-columns:1fr;gap:1rem;" class="sm:grid-cols-2">
            <div>
              <label for="ContactForm-name" style="display:block;font-size:0.875rem;font-weight:500;color:#334155;margin-bottom:0.375rem;">
                Naam <span style="color:#dc2626;">*</span>
              </label>
              <input
                type="text"
                name="contact[name]"
                id="ContactForm-name"
                required
                aria-required="true"
                placeholder="Uw volledige naam"
                style="width:100%;padding:0.75rem 1rem;border:1px solid #cbd5e1;border-radius:0.375rem;font-size:0.9375rem;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#475569'"
                onblur="this.style.borderColor='#cbd5e1'"
              >
            </div>
            <div>
              <label for="ContactForm-email" style="display:block;font-size:0.875rem;font-weight:500;color:#334155;margin-bottom:0.375rem;">
                E-mail <span style="color:#dc2626;">*</span>
              </label>
              <input
                type="email"
                name="contact[email]"
                id="ContactForm-email"
                required
                aria-required="true"
                placeholder="uw.email@voorbeeld.nl"
                autocomplete="email"
                style="width:100%;padding:0.75rem 1rem;border:1px solid #cbd5e1;border-radius:0.375rem;font-size:0.9375rem;background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='#475569'"
                onblur="this.style.borderColor='#cbd5e1'"
              >
            </div>
          </div>

          <!-- Subject -->
          <div>
            <label for="ContactForm-subject" style="display:block;font-size:0.875rem;font-weight:500;color:#334155;margin-bottom:0.375rem;">
              Onderwerp
            </label>
            <input
              type="text"
              name="contact[subject]"
              id="ContactForm-subject"
              placeholder="Waar gaat uw bericht over?"
              style="width:100%;padding:0.75rem 1rem;border:1px solid #cbd5e1;border-radius:0.375rem;font-size:0.9375rem;background:#fff;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#475569'"
              onblur="this.style.borderColor='#cbd5e1'"
            >
          </div>

          <!-- Message -->
          <div>
            <label for="ContactForm-body" style="display:block;font-size:0.875rem;font-weight:500;color:#334155;margin-bottom:0.375rem;">
              Bericht <span style="color:#dc2626;">*</span>
            </label>
            <textarea
              name="contact[body]"
              id="ContactForm-body"
              rows="6"
              required
              placeholder="Typ hier uw bericht..."
              style="width:100%;padding:0.75rem 1rem;border:1px solid #cbd5e1;border-radius:0.375rem;font-size:0.9375rem;background:#fff;outline:none;resize:vertical;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='#475569'"
              onblur="this.style.borderColor='#cbd5e1'"
            ></textarea>
          </div>

          <!-- Submit + Trust -->
          <div style="padding-top:0.5rem;">
            <button
              type="submit"
              style="background:#334155;color:#fff;font-weight:600;padding:0.875rem 2rem;border-radius:0.5rem;border:none;font-size:0.9375rem;cursor:pointer;transition:background 0.2s;"
              onmouseenter="this.style.background='#1e293b'"
              onmouseleave="this.style.background='#334155'"
            >
              Verstuur bericht
            </button>
            <div style="display:flex;align-items:center;gap:0.375rem;margin-top:0.75rem;">
              <svg style="width:0.875rem;height:0.875rem;color:#10b981;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <span style="font-size:0.8125rem;color:#64748b;">Uw gegevens worden vertrouwelijk behandeld</span>
            </div>
          </div>
        </div>
      {% endform %}
    </div>
  </section>

  <!-- ========== 3. MAP SECTION ========== -->
  <section aria-labelledby="map-heading" style="margin-bottom:3rem;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="map-heading" style="font-size:1.5rem;font-weight:700;color:#0f172a;margin-bottom:1.5rem;">
        Onze locatie
      </h2>
      <div style="width:100%;min-height:400px;border-radius:0.75rem;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.08);border:1px solid #e2e8f0;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2455.531414663473!2d4.657942999999999!3d52.015415999999995!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c5d112d3342f67%3A0x669e2b9712be9836!2sLoopzo%20%E2%80%93%20Loopfiets%20voor%20volwassenen!5e0!3m2!1snl!2sbd!4v1764665590062!5m2!1snl!2sbd"
          width="100%"
          height="450"
          style="border:0;display:block;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Loopzo Showroom locatie in Moordrecht, Nederland"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- ========== 4. COMPANY DETAILS (Merged, no duplication) ========== -->
  <section style="margin-bottom:2rem;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div style="position:relative;width:100%;border-radius:0.75rem;overflow:hidden;">
        <!-- Background Image -->
        <img
          src="https://cdn.shopify.com/s/files/1/0983/3476/9483/files/WhatsApp_Image_2026-03-26_at_14.46.51_1.jpg?v=1774515992"
          alt="Loopzo medewerker"
          width="1920"
          height="1080"
          style="width:100%;height:auto;object-fit:cover;display:block;"
          loading="lazy"
        >
        <!-- Company Info Overlay -->
        <div style="position:absolute;inset:0;display:flex;align-items:center;">
          <div style="width:100%;padding:2rem;">
            <div style="display:flex;flex-wrap:wrap;gap:2rem;padding:1.5rem;background:rgba(30,41,59,0.85);backdrop-filter:blur(8px);border-radius:0.5rem;width:100%;max-width:700px;">

              <!-- Address -->
              <div style="flex:1;min-width:180px;">
                <p style="font-size:0.75rem;font-weight:600;color:rgba(255,255,255,0.7);margin:0 0 0.375rem;text-transform:uppercase;letter-spacing:0.05em;">Adres</p>
                <p style="font-size:0.875rem;color:#fff;margin:0;">Zuidbaan 548H</p>
                <p style="font-size:0.875rem;color:#fff;margin:0;">2841MD Moordrecht, Nederland</p>
              </div>

              <!-- Company Details -->
              <div style="flex:1;min-width:180px;">
                <p style="font-size:0.75rem;font-weight:600;color:rgba(255,255,255,0.7);margin:0 0 0.375rem;text-transform:uppercase;letter-spacing:0.05em;">Bedrijfsgegevens</p>
                <p style="font-size:0.875rem;color:#fff;margin:0;">Loopzo</p>
                <p style="font-size:0.875rem;color:#fff;margin:0.25rem 0 0;">KvK: 85858552</p>
                <p style="font-size:0.875rem;color:#fff;margin:0.25rem 0 0;">BTW: NL004158990B08</p>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</div>
