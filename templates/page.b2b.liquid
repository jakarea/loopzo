<!-- Hero Section -->
<section class="relative bg-gradient-to-br from-slate-700 to-slate-800 py-16 sm:py-20 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-4xl mx-auto">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
        Word distributeur van Loopzo
      </h1>
      <p class="text-lg sm:text-xl text-slate-200 leading-relaxed">
        Sluit je aan bij ons groeiende netwerk van partners die kwaliteit en persoonlijke service centraal stellen
      </p>
    </div>
  </div>

  <!-- Decorative Wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg
      class="w-full h-12 sm:h-16 text-white"
      preserveAspectRatio="none"
      viewBox="0 0 1440 54"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
          d="M0 22L60 25.3C120 28.7 240 35.3 360 37.8C480 40.3 600 38.7 720 35.3C840 32 960 26.7 1080 23.5C1200 20.3 1320 19.3 1380 18.8L1440 18.3V54H1380C1320 54 1200 54 1080 54C960 54 840 54 720 54C600 54 480 54 360 54C240 54 120 54 60 54H0V22Z"
          fill="currentColor" />
    </svg>
  </div>
</section>

<!-- Content Section -->
<section class="bg-white py-12 sm:py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Introduction -->
    <div class="max-w-4xl mx-auto mb-16 text-center">
      <p class="text-lg text-slate-700 leading-relaxed">
        Loopzo staat voor kwaliteit, comfort en aandacht voor detail. Onze loopfietsen voor volwassenen zijn ontworpen
        in Nederland en winnen snel aan bekendheid in binnen- en buitenland. Daarom breiden we ons netwerk uit met
        distributeurs die onze waarden delen en het merk lokaal willen vertegenwoordigen.
      </p>
    </div>

    <!-- What We Look For Section -->
    <div class="mb-16">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-8 text-center">
          Wat we zoeken in een distributeur
        </h2>

        <!-- Logistics Image -->
        <div class="mb-8 flex justify-center">
          <img
            src="{{ 'loopzo_logistic.png' | asset_url }}"
            alt="Loopzo logistiek en distributie"
            width="800"
            height="400"
            class="max-w-full h-auto rounded-xl shadow-lg"
            loading="lazy"
          >
        </div>

        <div class="bg-slate-50 rounded-2xl p-8 sm:p-10 shadow-lg">
          <p class="text-base text-slate-700 leading-relaxed mb-8">
            We werken graag samen met partners die ervaring hebben in de mobiliteits- of revalidatiebranche en die oog
            hebben voor persoonlijke service.
          </p>
          <div class="space-y-6">
            <h3 class="text-xl font-bold text-slate-900 mb-4">Belangrijk voor ons is dat je:</h3>

            <!-- Requirement 1 -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div
                  class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center"
                >
                  <svg
                    class="w-6 h-6 text-slate-700"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                  </svg>
                </div>
              </div>
              <div class="flex-1">
                <h4 class="font-semibold text-slate-900 mb-2">Een betrouwbaar netwerk hebt in jouw regio</h4>
                <p class="text-slate-600 text-sm leading-relaxed">
                  Je hebt sterke connecties met klanten, zorginstellingen of revalidatiecentra in je gebied
                </p>
              </div>
            </div>

            <!-- Requirement 2 -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div
                  class="w-12 h-12 rounded-full bg-teal-100 flex items-center justify-center"
                >
                  <svg
                    class="w-6 h-6 text-teal-700"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  </svg>
                </div>
              </div>
              <div class="flex-1">
                <h4 class="font-semibold text-slate-900 mb-2">Klantgericht werkt en gelooft in duurzame mobiliteit</h4>
                <p class="text-slate-600 text-sm leading-relaxed">
                  Persoonlijke aandacht en het welzijn van de eindgebruiker staan bij jou voorop
                </p>
              </div>
            </div>

            <!-- Requirement 3 -->
            <div class="flex gap-4">
              <div class="flex-shrink-0">
                <div
                  class="w-12 h-12 rounded-full bg-teal-100 flex items-center justify-center"
                >
                  <svg
                    class="w-6 h-6 text-teal-700"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                </div>
              </div>
              <div class="flex-1">
                <h4 class="font-semibold text-slate-900 mb-2">Waarde hecht aan kwaliteit en langdurige samenwerking</h4>
                <p class="text-slate-600 text-sm leading-relaxed">
                  Je zoekt een partnership op de lange termijn, gebaseerd op vertrouwen en kwaliteit
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- What We Offer Section -->
    <div class="mb-16">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-8 text-center">Wat wij bieden</h2>
        <p class="text-base text-slate-700 leading-relaxed mb-8 text-center">
          Als distributeur van Loopzo kun je rekenen op:
        </p>
        <div class="grid sm:grid-cols-2 gap-6">
          <!-- Benefit 1 -->
          <div class="bg-white border-2 border-slate-200 rounded-2xl p-6 hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 rounded-full bg-slate-700 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Exclusieve regioafspraken</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Bescherming van jouw verkoopgebied voor optimale groei</p>
          </div>

          <!-- Benefit 2 -->
          <div class="bg-white border-2 border-slate-200 rounded-2xl p-6 hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 rounded-full bg-slate-700 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Ondersteuning met marketingmateriaal</h3>
            <p class="text-slate-600 text-sm leading-relaxed">Professionele brochures, displays en merkcommunicatie</p>
          </div>

          <!-- Benefit 3 -->
          <div class="bg-white border-2 border-slate-200 rounded-2xl p-6 hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 rounded-full bg-slate-700 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Producttraining en technische informatie</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Volledige kennis om jouw team optimaal voor te bereiden
            </p>
          </div>

          <!-- Benefit 4 -->
          <div class="bg-white border-2 border-slate-200 rounded-2xl p-6 hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 rounded-full bg-slate-700 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Snelle en zorgvuldige levering</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Betrouwbare logistiek voor tijdige levering aan jouw klanten
            </p>
          </div>

          <!-- Benefit 5 -->
          <div class="bg-white border-2 border-slate-200 rounded-2xl p-6 hover:shadow-lg transition-shadow sm:col-span-2">
            <div class="w-14 h-14 rounded-full bg-slate-700 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Een betrokken team dat met je meedenkt</h3>
            <p class="text-slate-600 text-sm leading-relaxed">
              Persoonlijk aanspreekpunt voor vragen, ondersteuning en strategisch advies
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Partnership Section -->
    <div class="mb-16">
      <div class="max-w-4xl mx-auto bg-slate-50 rounded-2xl p-8 sm:p-10 shadow-lg text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">Samen bouwen aan Loopzo</h2>
        <p class="text-base text-slate-700 leading-relaxed">
          We geloven in samenwerking op basis van vertrouwen, open communicatie en wederzijds succes. Als distributeur
          vertegenwoordig je een merk dat staat voor zorgvuldigheid, comfort en beweging met vertrouwen.
        </p>
      </div>
    </div>

    <!-- Contact Form Section -->
    <div class="max-w-4xl mx-auto">
      <div class="bg-gradient-to-br from-slate-700 to-slate-800 rounded-2xl p-8 sm:p-12 shadow-2xl">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-2 text-center">Geïnteresseerd?</h2>
        <p class="text-lg text-slate-200 mb-8 text-center">We nemen graag contact met je op</p>

        {% form 'contact', class: 'space-y-6' %}
          {% if form.posted_successfully? %}
            <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg mb-6">
              Bedankt voor je interesse! We nemen zo snel mogelijk contact met je op.
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mb-6">
              <p class="font-semibold">Er zijn enkele problemen met je inzending:</p>
              <ul class="list-disc list-inside mt-2">
                {% for field in form.errors %}
                  <li>{{ field }} - {{ form.errors.messages[field] }}</li>
                {% endfor %}
              </ul>
            </div>
          {% endif %}

          <!-- Company Name -->
          <div>
            <label for="ContactForm-company" class="block text-sm font-semibold text-white mb-2">
              Bedrijfsnaam <span class="text-slate-300">*</span>
            </label>
            <input
              type="text"
              id="ContactForm-company"
              name="contact[company]"
              required
              class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-transparent transition"
            >
          </div>

          <!-- Contact Person -->
          <div>
            <label for="ContactForm-name" class="block text-sm font-semibold text-white mb-2">
              Naam contactpersoon <span class="text-slate-300">*</span>
            </label>
            <input
              type="text"
              id="ContactForm-name"
              name="contact[name]"
              required
              class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-transparent transition"
            >
          </div>

          <!-- Email and Phone -->
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="ContactForm-email" class="block text-sm font-semibold text-white mb-2">
                E-mailadres <span class="text-slate-300">*</span>
              </label>
              <input
                type="email"
                id="ContactForm-email"
                name="contact[email]"
                required
                class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-transparent transition"
              >
            </div>
            <div>
              <label for="ContactForm-phone" class="block text-sm font-semibold text-white mb-2">
                Telefoonnummer <span class="text-slate-300">*</span>
              </label>
              <input
                type="tel"
                id="ContactForm-phone"
                name="contact[phone]"
                required
                class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-transparent transition"
              >
            </div>
          </div>

          <!-- Country -->
          <div>
            <label for="ContactForm-country" class="block text-sm font-semibold text-white mb-2">
              Land <span class="text-slate-300">*</span>
            </label>
            <select
              id="ContactForm-country"
              name="contact[country]"
              required
              class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-transparent transition"
            >
              <option value="" class="text-slate-900">Selecteer land</option>
              <option value="nederland" class="text-slate-900">Nederland</option>
              <option value="belgie" class="text-slate-900">België</option>
              <option value="duitsland" class="text-slate-900">Duitsland</option>
              <option value="frankrijk" class="text-slate-900">Frankrijk</option>
              <option value="anders" class="text-slate-900">Anders</option>
            </select>
          </div>

          <!-- Branch -->
          <div>
            <label for="ContactForm-industry" class="block text-sm font-semibold text-white mb-2">
              Branche <span class="text-slate-300">*</span>
            </label>
            <select
              id="ContactForm-industry"
              name="contact[industry]"
              required
              class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white focus:outline-none focus:ring-2 focus:ring-slate-500 focus:border-transparent transition"
            >
              <option value="" class="text-slate-900">Selecteer branche</option>
              <option value="zorg" class="text-slate-900">Zorg</option>
              <option value="revalidatie" class="text-slate-900">Revalidatie</option>
              <option value="fietsen" class="text-slate-900">Fietsen</option>
              <option value="anders" class="text-slate-900">Anders</option>
            </select>
          </div>

          <!-- Comments -->
          <div>
            <label for="ContactForm-body" class="block text-sm font-semibold text-white mb-2">
              Opmerkingen/vragen
            </label>
            <textarea
              id="ContactForm-body"
              name="contact[body]"
              rows="4"
              class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition resize-none"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <div class="text-center pt-4">
            <button
              type="submit"
              class="inline-flex items-center bg-slate-700 hover:bg-slate-800 text-white px-8 py-4 rounded-xl font-semibold text-base transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 group"
            >
              Verstuur aanvraag
              <svg
                class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform duration-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </button>
          </div>
        {% endform %}
      </div>
    </div>
  </div>
</section>
