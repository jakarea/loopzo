{% comment %}
  Blog Article Template
  Displays individual blog posts with hero section, content, author bio, share buttons, and related articles
{% endcomment %}

{% comment %} Calculate reading time {% endcomment %}
{% assign words = article.content | strip_html | number_of_words %}
{% assign reading_time = words | divided_by: 200 | at_least: 1 %}

{% comment %} Get category color {% endcomment %}
{% assign category_colors = "teal,slate,amber,purple,red,teal" | split: "," %}
{% assign color_index = 0 %}
{% if article.tags.size > 0 %}
  {% assign color_index = article.tags.first | size | modulo: 5 %}
{% endif %}
{% assign category_color = category_colors[color_index] %}

<!-- Hero Section -->
<section class="relative bg-gradient-to-br from-slate-700 to-slate-800 py-12 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Article Header -->
        <div class="max-w-4xl mx-auto">
            {% if article.tags.size > 0 %}
                <span class="inline-block bg-{{ category_color }}-700 text-white text-sm font-semibold px-4 py-2 rounded-lg mb-4">
                    {{ article.tags.first }}
                </span>
            {% else %}
                <span class="inline-block bg-slate-700 text-white text-sm font-semibold px-4 py-2 rounded-lg mb-4">
                    Nieuws
                </span>
            {% endif %}
            
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
                {{ article.title }}
            </h1>

            <!-- Date and Reading Time -->
            <div class="flex items-center gap-6 text-slate-200 text-sm">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span>{{ article.published_at | date: "%d %B %Y" }}</span>
                </div>
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>{{ reading_time }} min lezen</span>
                </div>
            </div>
        </div>
    </div>
    <!-- Decorative Wave -->
    <div class="absolute bottom-0 left-0 right-0">
        <svg class="w-full h-12 sm:h-16 text-white" preserveAspectRatio="none" viewBox="0 0 1440 54" fill="none"
            xmlns="http://www.w3.org/2000/svg">
            <path
                d="M0 22L60 25.3C120 28.7 240 35.3 360 37.8C480 40.3 600 38.7 720 35.3C840 32 960 26.7 1080 23.5C1200 20.3 1320 19.3 1380 18.8L1440 18.3V54H1380C1320 54 1200 54 1080 54C960 54 840 54 720 54C600 54 480 54 360 54C240 54 120 54 60 54H0V22Z"
                fill="currentColor" />
        </svg>
    </div>
</section>

<!-- Article Content -->
<article class="bg-white py-12 sm:py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Featured Image -->
        {% if article.image %}
            <div class="rounded-2xl overflow-hidden shadow-2xl mb-8 article-featured-image">
                <img src="{{ article.image | image_url: width: 1200 }}"
                     alt="{{ article.image.alt | default: article.title }}"
                     width="1200"
                     height="675"
                     class="w-full h-auto"
                     loading="eager">
            </div>
        {% endif %}

        <!-- Article Body -->
        <div class="prose prose-lg max-w-none article-content">
            {{ article.content }}
        </div>

        <!-- Author Info -->
        {% render 'article-author-bio' %}

        <!-- Share Buttons -->
        <div class="mt-8 pt-8 border-t border-slate-200">
            <p class="text-sm font-semibold text-slate-900 mb-4">Deel dit artikel:</p>
            <div class="flex gap-3">
                <!-- Facebook -->
                <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-slate-700 text-white hover:bg-slate-800 transition-colors"
                   aria-label="Deel op Facebook">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path
                            d="M12 2.04C6.5 2.04 2 6.53 2 12.06C2 17.06 5.66 21.21 10.44 21.96V14.96H7.9V12.06H10.44V9.81C10.44 7.31 11.93 5.96 14.22 5.96C15.31 5.96 16.45 6.15 16.45 6.15V8.62H15.19C13.95 8.62 13.56 9.39 13.56 10.18V12.06H16.34L15.89 14.96H13.56V21.96C18.34 21.21 22 17.06 22 12.06C22 6.53 17.5 2.04 12 2.04Z">
                        </path>
                    </svg>
                </a>
                
                <!-- Twitter -->
                <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-slate-700 text-white hover:bg-slate-800 transition-colors"
                   aria-label="Deel op Twitter">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path
                            d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z">
                        </path>
                    </svg>
                </a>
                
                <!-- LinkedIn -->
                <a href="https://www.linkedin.com/shareArticle?mini=true&url={{ shop.url }}{{ article.url }}&title={{ article.title | url_encode }}"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-slate-700 text-white hover:bg-slate-800 transition-colors"
                   aria-label="Deel op LinkedIn">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path
                            d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                    </svg>
                </a>
            </div>
        </div>
    </div>
</article>

<!-- Related Blogs Section -->
<section class="bg-slate-50 py-12 sm:py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
            <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
                Gerelateerde Artikelen
            </h2>
            <p class="text-lg text-slate-600">
                Ontdek meer inspirerende verhalen en tips
            </p>
        </div>

        <!-- Related Blog Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% assign count = 0 %}
            {% for related_article in blog.articles %}
                {% if related_article.id == article.id %}
                    {% continue %}
                {% endif %}
                
                {% assign count = count | plus: 1 %}
                
                {% assign related_category_colors = "teal,slate,amber,purple,red,teal" | split: "," %}
                {% assign related_color_index = forloop.index0 | modulo: 6 %}
                {% assign related_category_color = related_category_colors[related_color_index] %}

                <!-- Related Card {{ count }} -->
                <article
                    class="group rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
                    <a href="{{ related_article.url }}" class="block relative aspect-[3/4] overflow-hidden">
                        {% if related_article.image %}
                            <img src="{{ related_article.image | image_url: width: 600 }}"
                                 alt="{{ related_article.image.alt | default: related_article.title }}"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                 loading="lazy">
                        {% else %}
                            <div class="w-full h-full bg-gradient-to-br from-slate-200 to-slate-300 flex items-center justify-center">
                                <svg class="w-24 h-24 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                        {% endif %}
                        
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent">
                        </div>
                        
                        <div class="absolute inset-0 p-6 flex flex-col justify-between">
                            <div>
                                {% if related_article.tags.size > 0 %}
                                    <span
                                        class="inline-block bg-{{ related_category_color }}-700 text-white text-xs font-semibold px-3 py-1.5 rounded-md">
                                        {{ related_article.tags.first }}
                                    </span>
                                {% else %}
                                    <span
                                        class="inline-block bg-slate-700 text-white text-xs font-semibold px-3 py-1.5 rounded-md">
                                        Nieuws
                                    </span>
                                {% endif %}
                            </div>
                            
                            <div>
                                <h3 class="text-white text-xl font-bold mb-3 leading-tight">
                                    {{ related_article.title }}
                                </h3>
                                <span
                                    class="inline-flex items-center text-white text-sm font-semibold group-hover:gap-2 transition-all">
                                    Read more
                                    <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform"
                                        fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                    </svg>
                                </span>
                            </div>
                        </div>
                    </a>
                </article>
                
                {% if count == 3 %}
                    {% break %}
                {% endif %}
            {% endfor %}

        </div>

        <!-- View All Button -->
        <div class="text-center mt-12">
            <a href="{{ blog.url }}"
                class="inline-flex items-center bg-slate-800 text-white px-8 py-4 rounded-xl font-semibold text-base hover:bg-slate-900 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 group">
                Bekijk alle artikelen
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform duration-300"
                    fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
            </a>
        </div>
    </div>
</section>

<style>
/* Article Content Styling */
.article-content {
    color: #334155;
}

.article-content p {
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
    color: #475569;
}

.article-content p:first-of-type {
    font-size: 1.125rem;
    color: #334155;
}

.article-content h2 {
    font-size: 1.875rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
}

.article-content h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
}

.article-content ul,
.article-content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: #475569;
}

.article-content li {
    margin-bottom: 0.5rem;
}

.article-content ul {
    list-style-type: disc;
}

.article-content ol {
    list-style-type: decimal;
}

.article-content blockquote {
    border-left: 4px solid #0f766e;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    font-size: 1.125rem;
    color: #475569;
}

.article-content a {
    color: #0f766e;
    text-decoration: underline;
}

.article-content a:hover {
    color: #115e59;
}

.article-content img {
    border-radius: 0.5rem;
    margin: 2rem 0;
}

.article-content strong {
    font-weight: 600;
    color: #0f172a;
}

.article-content em {
    font-style: italic;
}

@media (min-width: 640px) {
    .article-content h2 {
        font-size: 2.25rem;
    }
    
    .article-content h3 {
        font-size: 1.875rem;
    }
}
</style>
