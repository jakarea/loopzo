{% comment %} Collection Header {% endcomment %}
<div class="collect_header">
  <div class="max-w-7xl mx-auto px-4 relative hero-height">
    <div class="grid grid-cols-1">
      <div class="desktop-display">
        <h1>{{ collection.title }}</h1>
        <p>{{ collection.metafields.custom.header_title_descriptions }}</p>
      </div>
    </div>
    <div class="absolute right-0 bottom-0 z-40 h-full w-full flex justify-end hero-image-wrapper">
      <img src="https://cdn.shopify.com/s/files/1/0983/3476/9483/files/Man_image.webp?v=1775055181" class="object-contain " alt="Loopzo collection" >
    </div>
  </div>
</div>





{% if template contains 'list-collections' %}
  {% assign current_collection = collections['all'] %}
{% else %}
  {% assign current_collection = collection %}
{% endif %}

<section class="bg-white pt-8 sm:pt-16 md:pt-20 pb-10 sm:pb-14 md:pb-16" id="collection-products">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {% comment %} Breadcrumb {% endcomment %}
    <nav class="flex items-center gap-2 text-lg mb-6 sm:mb-8" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}" class="text-slate-600 hover:text-slate-900 transition">
        {{ 'general.breadcrumbs.home' | t }}
      </a>

      <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>

      <a href="{{ routes.all_products_collection_url }}" class="text-slate-600 hover:text-slate-900 transition">
        {{ 'products.product.products' | t }}
      </a>

      {% if current_collection %}
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>

        <span class="text-slate-900 font-medium">
          {{ current_collection.title }}
        </span>
      {% endif %}
    </nav>

    {% if current_collection %}

      {% comment %} Description {% endcomment %}
      <div class="mb-8 sm:mb-10 md:mb-12">
        {% if current_collection.description != blank %}
          <div class="mt-3lg sm:text-base text-slate-700 max-w-3xl prose prose-slate">
            {{ current_collection.description }}
          </div>
        {% elsif template contains 'list-collections' %}
          <p class="mt-3 text-sm sm:text-base text-slate-700 max-w-3xl">
            Ontdek al onze Loopzo producten in één overzicht.
          </p>
        {% endif %}
      </div>

      {% paginate current_collection.products by 12 %}
        {% if current_collection.products_count > 0 %}

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">

            {% for product in current_collection.products %}
              <article class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-200 hover:border-slate-300 hover:shadow-lg transition flex flex-col">

                <a href="{{ product.url }}" class="block relative bg-slate-50">
                  <div class="aspect-square w-full overflow-hidden">

                    {% if product.featured_media %}
                      {% render 'product-media', media: product.featured_media, class: 'w-full h-full' %}
                    {% else %}
                      <div class="flex items-center justify-center w-full h-full bg-slate-100">
                        {{ 'product-1' | placeholder_svg_tag: 'w-20 h-20 text-slate-300' }}
                      </div>
                    {% endif %}

                  </div>

                  {% assign compare = product.selected_or_first_available_variant.compare_at_price %}
                  {% assign price = product.selected_or_first_available_variant.price %}

                  {% if compare > price %}
                    <div class="absolute top-3 left-3 bg-red-500 text-white px-2 py-1 text-xs rounded-full">
                      {{ 'products.product.sale_badge' | t }}
                    </div>
                  {% endif %}

                  {% unless product.available %}
                    <div class="absolute top-3 right-3 bg-slate-800/85 text-white px-2 py-1 text-xs rounded-full">
                      {{ 'products.product.sold_out' | t }}
                    </div>
                  {% endunless %}

                </a>

                <div class="p-4 flex flex-col flex-1">

                  <h2 class="text-lg font-semibold text-slate-900 mb-2 min-h-[56px] leading-snug">
                    <a href="{{ product.url }}" class="hover:underline">
                      {{ product.title | escape }}
                    </a>
                  </h2>

                  <div class="mb-3">
                    {% render 'price',
                      product: product,
                      use_variant: true,
                      show_badges: true,
                      price_class: 'text-xl font-bold text-slate-900'
                    %}
                  </div>

                  <div class="text-xs mb-4 flex items-center gap-2 text-slate-600">
                    {% if product.available %}
                      <span class="flex items-center gap-1">
                        <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                        {{ 'products.product.stock.in_stock' | t }}
                      </span>
                    {% else %}
                      <span class="flex items-center gap-1">
                        <span class="w-2 h-2 bg-red-500 rounded-full"></span>
                        {{ 'products.product.stock.out_of_stock' | t }}
                      </span>
                    {% endif %}
                  </div>

                  <a href="{{ product.url }}"
                     class="mt-auto text-center bg-slate-800 text-white py-2 px-4 rounded-lg font-medium hover:bg-slate-700 transition">
                    {{ 'products.product.view_details' | t }}
                  </a>

                </div>

              </article>
            {% endfor %}

          </div>

          {% if paginate.pages > 1 %}
            <div class="mt-10 flex justify-between items-center text-sm">

              {% if paginate.previous %}
                <a href="{{ paginate.previous.url }}" class="px-3 py-2 border rounded hover:bg-slate-50">
                  ← Previous
                </a>
              {% endif %}

              <span class="font-medium">
                {{ paginate.current_page }} / {{ paginate.pages }}
              </span>

              {% if paginate.next %}
                <a href="{{ paginate.next.url }}" class="px-3 py-2 border rounded hover:bg-slate-50">
                  Next →
                </a>
              {% endif %}

            </div>
          {% endif %}

        {% else %}
          <div class="text-center py-10">
            <h2 class="text-lg font-semibold">No products found</h2>
          </div>
        {% endif %}
      {% endpaginate %}

    {% else %}
      <div class="text-center py-10">
        <h2 class="text-lg font-semibold">Collection not found</h2>
      </div>
    {% endif %}

  </div>
</section>

{% comment %} Footer {% endcomment %}
<div class="collect_footer">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1">
      <div class="footer-seo-text">
        <h2 class="text-lg font-semibold text-slate-900 mb-2 min-h-[56px] leading-snug mt-6">{{ collection.metafields.custom.footer_title }}</h2>
        <p>{{ collection.metafields.custom.footer_title_descriptions }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Loopzo Collection Grid",
  "tag": "section",
  "class": "section",
  "settings": [],
  "presets": [
    {
      "name": "Loopzo Collection Grid"
    }
  ]
}
{% endschema %}