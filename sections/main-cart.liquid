{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="bg-slate-50 section-{{ section.id }}-padding">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12 lg:py-16">

    <!-- Cart Header -->
    <div class="mb-8 sm:mb-12">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-2">Winkelwagen</h1>
      <p class="text-slate-600">
        {% if cart.item_count > 0 %}
          Je hebt {{ cart.item_count }} {% if cart.item_count == 1 %}product{% else %}producten{% endif %} in je winkelwagen
        {% else %}
          Je winkelwagen is leeg
        {% endif %}
      </p>
    </div>

    {% if cart.item_count > 0 %}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">

        <!-- Cart Items (Left Column) -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-lg overflow-hidden">

            <!-- Cart Items List -->
            <form action="{{ routes.cart_url }}" method="post" id="cart-form">
              <div class="divide-y divide-slate-200">
                {% for item in cart.items %}
                  <div class="p-6 cart-item" data-index="{{ forloop.index }}">
                    <div class="flex gap-4 sm:gap-6">

                      <!-- Product Image -->
                      <div class="flex-shrink-0">
                        <a href="{{ item.url }}" class="block w-24 h-24 sm:w-32 sm:h-32 rounded-lg overflow-hidden bg-slate-100">
                          {% if item.image %}
                            <img src="{{ item.image | image_url: width: 300 }}"
                                 alt="{{ item.image.alt | escape }}"
                                 class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                                 loading="lazy">
                          {% else %}
                            <div class="w-full h-full flex items-center justify-center">
                              <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                              </svg>
                            </div>
                          {% endif %}
                        </a>
                      </div>

                      <!-- Product Details -->
                      <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-start gap-4 mb-3">
                          <div class="flex-1 min-w-0">
                            <h3 class="text-lg font-semibold text-slate-900 mb-1">
                              <a href="{{ item.url }}" class="hover:text-slate-600 transition">
                                {{ item.product.title }}
                              </a>
                            </h3>

                            <!-- Variant Info -->
                            {% unless item.variant.title == 'Default Title' %}
                              <p class="text-sm text-slate-600">
                                {{ item.variant.title }}
                              </p>
                            {% endunless %}

                            <!-- Unit Price with Compare Price -->
                            <div class="flex items-center gap-2 mt-2">
                              {% if item.variant.compare_at_price > item.variant.price %}
                                <span class="text-sm text-slate-500 line-through">
                                  {{ item.variant.compare_at_price | money }}
                                </span>
                                <span class="text-sm font-semibold text-red-600">
                                  {{ item.variant.price | money }}
                                </span>
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">
                                  {% assign savings = item.variant.compare_at_price | minus: item.variant.price | times: 100.0 | divided_by: item.variant.compare_at_price | round %}
                                  -{{ savings }}%
                                </span>
                              {% else %}
                                <span class="text-sm font-semibold text-slate-700">
                                  {{ item.variant.price | money }} / stuk
                                </span>
                              {% endif %}
                            </div>

                            <!-- Properties/Customizations -->
                            {% if item.properties.size > 0 %}
                              <div class="mt-2 text-sm text-slate-600">
                                {% for property in item.properties %}
                                  {% unless property.last == blank %}
                                    <p>{{ property.first }}: {{ property.last }}</p>
                                  {% endunless %}
                                {% endfor %}
                              </div>
                            {% endif %}
                          </div>

                          <!-- Remove Button (Desktop) -->
                          <button type="button"
                                  onclick="removeFromCart({{ forloop.index }})"
                                  class="hidden sm:flex items-center justify-center w-9 h-9 rounded-lg text-slate-400 hover:text-red-600 hover:bg-red-50 transition-all duration-200"
                                  aria-label="Verwijder {{ item.product.title }}">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                          </button>
                        </div>

                        <!-- Quantity and Price Row -->
                        <div class="flex flex-wrap items-center justify-between gap-4">

                          <!-- Quantity Controls -->
                          <div class="flex items-center gap-3">
                            <label class="text-sm font-medium text-slate-700">Aantal:</label>
                            <div class="flex items-center border-2 border-slate-200 rounded-lg overflow-hidden">
                              <button type="button"
                                      onclick="updateQuantity({{ forloop.index }}, {{ item.quantity | minus: 1 }})"
                                      class="w-10 h-10 flex items-center justify-center text-slate-600 hover:bg-slate-100 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                                      {% if item.quantity <= 1 %}disabled{% endif %}
                                      aria-label="Verminder aantal">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"></path>
                                </svg>
                              </button>

                              <input type="number"
                                     name="updates[]"
                                     id="updates_{{ forloop.index }}"
                                     value="{{ item.quantity }}"
                                     min="0"
                                     class="w-14 h-10 text-center border-x-2 border-slate-200 font-semibold text-slate-900 focus:outline-none"
                                     onchange="updateQuantity({{ forloop.index }}, this.value)"
                                     aria-label="Aantal voor {{ item.product.title }}">

                              <button type="button"
                                      onclick="updateQuantity({{ forloop.index }}, {{ item.quantity | plus: 1 }})"
                                      class="w-10 h-10 flex items-center justify-center text-slate-600 hover:bg-slate-100 transition-colors"
                                      aria-label="Verhoog aantal">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
                                </svg>
                              </button>
                            </div>
                          </div>

                          <!-- Price -->
                          <div class="text-right">
                            {% if item.original_line_price != item.final_line_price %}
                              <div class="text-sm text-slate-500 line-through">
                                {{ item.original_line_price | money }}
                              </div>
                              <div class="text-lg font-bold text-slate-900">
                                {{ item.final_line_price | money }}
                              </div>
                            {% else %}
                              <div class="text-lg font-bold text-slate-900">
                                {{ item.final_line_price | money }}
                              </div>
                            {% endif %}

                            {% if item.quantity > 1 %}
                              <div class="text-sm text-slate-500">
                                {{ item.final_price | money }} / stuk
                              </div>
                            {% endif %}
                          </div>
                        </div>

                        <!-- Remove Button (Mobile) -->
                        <button type="button"
                                onclick="removeFromCart({{ forloop.index }})"
                                class="sm:hidden mt-4 flex items-center gap-2 text-sm text-red-600 hover:text-red-700 font-medium"
                                aria-label="Verwijder {{ item.product.title }}">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                          </svg>
                          Verwijderen
                        </button>

                        <!-- Discounts -->
                        {% if item.line_level_discount_allocations.size > 0 %}
                          <div class="mt-3">
                            {% for discount in item.line_level_discount_allocations %}
                              <div class="flex items-center gap-2 text-sm text-green-700 bg-green-50 px-3 py-1.5 rounded-lg inline-flex">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                                </svg>
                                {{ discount.discount_application.title }} (-{{ discount.amount | money }})
                              </div>
                            {% endfor %}
                          </div>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                {% endfor %}
              </div>
            </form>

          </div>
        </div>

        <!-- Order Summary (Right Column) -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-2xl shadow-lg p-6 sm:p-8 sticky top-24">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">Besteloverzicht</h2>

            <!-- Coupon Code Section -->
            <div class="mb-6 pb-6 border-b border-slate-200">
              <details class="group">
                <summary class="flex items-center justify-between cursor-pointer text-slate-700 hover:text-slate-900 font-medium mb-3">
                  <span class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                    </svg>
                    Kortingscode toevoegen
                  </span>
                  <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </summary>
                <div class="mt-3">
                  <form action="{{ routes.cart_url }}" method="post" class="flex gap-2">
                    <input type="text"
                           name="discount"
                           id="discount-code"
                           placeholder="Kortingscode"
                           class="flex-1 px-4 py-2.5 border-2 border-slate-200 rounded-lg focus:border-slate-400 focus:outline-none text-sm"
                           value="{{ cart.attributes.discount }}">
                    <button type="submit"
                            name="checkout"
                            class="px-5 py-2.5 bg-slate-700 hover:bg-slate-800 text-white font-semibold rounded-lg transition-colors text-sm whitespace-nowrap">
                      Toepassen
                    </button>
                  </form>
                  <p class="text-xs text-slate-500 mt-2">
                    Je kunt kortingscodes ook toepassen bij het afrekenen
                  </p>
                </div>
              </details>
            </div>

            <!-- Subtotal -->
            <div class="space-y-4 mb-6 pb-6 border-b border-slate-200">
              <div class="flex justify-between text-slate-700">
                <span>Subtotaal</span>
                <span class="font-semibold">{{ cart.original_total_price | money }}</span>
              </div>

              <!-- Cart Level Discounts -->
              {% if cart.cart_level_discount_applications.size > 0 %}
                {% for discount in cart.cart_level_discount_applications %}
                  <div class="flex justify-between text-green-700">
                    <span class="flex items-center gap-2">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                      </svg>
                      {{ discount.title }}
                    </span>
                    <span class="font-semibold">-{{ discount.total_allocated_amount | money }}</span>
                  </div>
                {% endfor %}
              {% endif %}

              <!-- Shipping -->
              <div class="flex justify-between text-slate-700">
                <span>Verzendkosten</span>
                <span class="text-slate-500">Berekend bij afrekenen</span>
              </div>
            </div>

            <!-- Total -->
            <div class="flex justify-between items-center mb-8 pb-6 border-b border-slate-200">
              <span class="text-xl font-bold text-slate-900">Totaal</span>
              <span class="text-2xl font-bold text-slate-900">{{ cart.total_price | money }}</span>
            </div>

            <!-- Checkout Button -->
            <a href="{{ routes.checkout_url }}"
               class="block w-full bg-slate-700 hover:bg-slate-800 text-white text-center font-bold py-4 px-6 rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 mb-4">
              Afrekenen
            </a>

            <!-- Continue Shopping -->
            <a href="{{ routes.all_products_collection_url }}"
               class="block w-full text-center text-slate-600 hover:text-slate-900 font-medium py-3 transition">
              ← Verder winkelen
            </a>

            <!-- Trust Badges -->
            <div class="mt-8 pt-6 border-t border-slate-200 space-y-3">
              <div class="flex items-center gap-3 text-sm text-slate-600">
                <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
                <span>Veilig betalen</span>
              </div>
              <div class="flex items-center gap-3 text-sm text-slate-600">
                <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Gratis verzending vanaf €50</span>
              </div>
              <div class="flex items-center gap-3 text-sm text-slate-600">
                <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
                </svg>
                <span>30 dagen retourrecht</span>
              </div>
            </div>
          </div>
        </div>

      </div>

    {% else %}

      <!-- Empty Cart State -->
      <div class="bg-white rounded-2xl shadow-lg p-8 sm:p-12 lg:p-16 text-center max-w-2xl mx-auto">
        <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-12 h-12 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
          </svg>
        </div>
        <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">Je winkelwagen is leeg</h2>
        <p class="text-slate-600 mb-8">Begin met winkelen om producten toe te voegen aan je winkelwagen.</p>
        <a href="{{ routes.all_products_collection_url }}"
           class="inline-flex items-center gap-2 bg-slate-700 hover:bg-slate-800 text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          Bekijk producten
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>

    {% endif %}

  </div>
</div>

<script>
  // Update quantity
  function updateQuantity(lineIndex, newQuantity) {
    newQuantity = parseInt(newQuantity);

    if (newQuantity < 0) return;

    fetch('/cart/change.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        line: lineIndex,
        quantity: newQuantity
      })
    })
    .then(response => response.json())
    .then(data => {
      window.location.reload();
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Er ging iets mis bij het bijwerken van de winkelwagen. Probeer het opnieuw.');
    });
  }

  // Remove item from cart
  function removeFromCart(lineIndex) {
    if (confirm('Weet je zeker dat je dit product wilt verwijderen?')) {
      updateQuantity(lineIndex, 0);
    }
  }
</script>

{% schema %}
{
  "name": "Cart",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ]
}
{% endschema %}
