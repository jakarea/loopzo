{%- comment -%}
  Cart Page Section — Loopzo Theme
  Server-rendered with AJAX updates for quantity/remove actions.
{%- endcomment -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<!-- Breadcrumb -->
<div class="bg-slate-50 border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 sm:py-6">
    <nav class="flex items-center gap-2 text-sm" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}" class="text-slate-600 hover:text-slate-900 transition">{{ 'general.breadcrumbs.home' | t }}</a>
      <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span class="text-slate-900 font-medium">{{ 'general.cart.title' | t }}</span>
    </nav>
  </div>
</div>

<section class="section-{{ section.id }}-padding">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {%- if cart.item_count > 0 -%}

      <!-- Page Header -->
      <div class="mb-8">
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900">{{ 'general.cart.title' | t }}</h1>
        <p class="mt-1 text-sm text-slate-500">{{ 'general.cart.item_count' | t: count: cart.item_count }}</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">

        <!-- Cart Items (2/3 width) -->
        <div class="lg:col-span-2">

          <!-- Desktop Header -->
          <div class="hidden md:grid grid-cols-12 gap-4 pb-4 border-b border-slate-200 text-xs font-semibold text-slate-500 uppercase tracking-wider">
            <div class="col-span-6">{{ 'general.cart.label_product' | t }}</div>
            <div class="col-span-2 text-center">{{ 'general.cart.label_price' | t }}</div>
            <div class="col-span-2 text-center">{{ 'general.cart.label_quantity' | t }}</div>
            <div class="col-span-2 text-right">{{ 'general.cart.label_total' | t }}</div>
          </div>

          <!-- Cart Items Loop -->
          <form action="{{ routes.cart_url }}" method="post" id="cart-form" novalidate>
            {%- for item in cart.items -%}
              <div class="cart-item py-6 border-b border-slate-100" data-key="{{ item.key }}" data-price="{{ item.price }}">
                <div class="grid grid-cols-12 gap-4 items-center">

                  <!-- Product Image + Info -->
                  <div class="col-span-12 md:col-span-6 flex gap-4">
                    <a href="{{ item.url }}" class="flex-shrink-0 w-20 h-20 sm:w-24 sm:h-24 rounded-lg overflow-hidden border border-slate-200 bg-slate-50">
                      <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" class="w-full h-full object-cover" loading="lazy" width="200" height="200">
                    </a>
                    <div class="flex flex-col justify-center min-w-0">
                      <a href="{{ item.url }}" class="text-sm sm:text-base font-semibold text-slate-900 hover:text-slate-700 transition line-clamp-2">{{ item.product.title | escape }}</a>
                      {%- if item.variant.title != 'Default Title' -%}
                        <p class="text-xs sm:text-sm text-slate-500 mt-1">{{ item.variant.title | escape }}</p>
                      {%- endif -%}
                      {%- if item.selling_plan_allocation -%}
                        <p class="text-xs text-slate-500 mt-0.5">{{ item.selling_plan_allocation.selling_plan.name | escape }}</p>
                      {%- endif -%}
                      {%- if item.discounts.size > 0 -%}
                        <ul class="mt-1" aria-label="{{ 'general.cart.discounts' | t }}">
                          {%- for discount in item.discounts -%}
                            <li class="text-xs text-green-600">{{ discount.title | escape }}</li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                      <!-- Mobile-only: price + qty row -->
                      <div class="md:hidden flex items-center gap-4 mt-3">
                        <span class="text-sm font-semibold text-slate-900">{{ item.price | money }}</span>
                        <div class="flex items-center border border-slate-300 rounded-lg">
                          <button type="button" class="qty-btn w-8 h-8 flex items-center justify-center text-slate-600 hover:text-slate-900 transition" data-action="decrease" data-key="{{ item.key }}" aria-label="{{ 'general.cart.decrease' | t: product: item.title | escape }}">−</button>
                          <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="qty-input w-10 h-8 text-center text-sm border-x border-slate-300 bg-white focus:outline-none" data-key="{{ item.key }}" aria-label="{{ 'general.cart.quantity_label' | t: product: item.title | escape }}">
                          <button type="button" class="qty-btn w-8 h-8 flex items-center justify-center text-slate-600 hover:text-slate-900 transition" data-action="increase" data-key="{{ item.key }}" aria-label="{{ 'general.cart.increase' | t: product: item.title | escape }}">+</button>
                        </div>
                      </div>
                      <!-- Mobile remove -->
                      <button type="button" class="cart-remove-btn md:hidden mt-2 text-xs text-red-500 hover:text-red-700 transition" data-key="{{ item.key }}">{{ 'general.cart.remove' | t }}</button>
                    </div>
                  </div>

                  <!-- Unit Price (desktop) -->
                  <div class="hidden md:flex col-span-2 items-center justify-center">
                    <span class="text-sm text-slate-700">{{ item.price | money }}</span>
                  </div>

                  <!-- Quantity (desktop) -->
                  <div class="hidden md:flex col-span-2 items-center justify-center">
                    <div class="flex items-center border border-slate-300 rounded-lg">
                      <button type="button" class="qty-btn w-8 h-8 flex items-center justify-center text-slate-600 hover:text-slate-900 transition" data-action="decrease" data-key="{{ item.key }}" aria-label="{{ 'general.cart.decrease' | t: product: item.title | escape }}">−</button>
                      <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="qty-input w-10 h-8 text-center text-sm border-x border-slate-300 bg-white focus:outline-none" data-key="{{ item.key }}" aria-label="{{ 'general.cart.quantity_label' | t: product: item.title | escape }}">
                      <button type="button" class="qty-btn w-8 h-8 flex items-center justify-center text-slate-600 hover:text-slate-900 transition" data-action="increase" data-key="{{ item.key }}" aria-label="{{ 'general.cart.increase' | t: product: item.title | escape }}">+</button>
                    </div>
                  </div>

                  <!-- Line Total (desktop) -->
                  <div class="hidden md:flex col-span-2 items-center justify-end">
                    <span class="text-sm font-semibold text-slate-900 line-item-total" data-key="{{ item.key }}">{{ item.line_price | money }}</span>
                  </div>

                  <!-- Remove (desktop) -->
                  <div class="hidden md:flex col-span-12 justify-end -mt-4">
                    <button type="button" class="cart-remove-btn text-xs text-slate-400 hover:text-red-500 transition" data-key="{{ item.key }}">{{ 'general.cart.remove' | t }}</button>
                  </div>

                </div>
              </div>
            {%- endfor -%}
          </form>
        </div>

        <!-- Order Summary Sidebar (1/3 width) -->
        <div class="lg:col-span-1">
          <div class="bg-slate-50 border border-slate-200 rounded-xl p-6 sticky top-6">
            <h2 class="text-lg font-bold text-slate-900 mb-4">{{ 'general.cart.order_summary' | t }}</h2>

            <!-- Subtotal -->
            <div class="flex justify-between items-center py-3 border-b border-slate-200">
              <span class="text-sm text-slate-600">{{ 'general.cart.subtotal' | t }}</span>
              <span id="cart-subtotal" class="text-base font-bold text-slate-900">{{ cart.total_price | money }}</span>
            </div>

            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <div class="flex justify-between items-center py-3 border-b border-slate-200">
                <span class="text-sm text-green-600">{{ 'general.cart.discount' | t }}</span>
                <span class="text-sm text-green-600">
                  {%- for discount in cart.cart_level_discount_applications -%}
                    -{{ discount.total_allocated_amount | money }}
                  {%- endfor -%}
                </span>
              </div>
            {%- endif -%}

            <!-- Shipping note -->
            <p class="text-xs text-slate-500 mt-3">{{ 'general.cart.shipping_note' | t }}</p>

            <!-- Checkout Button -->
            <button type="submit" form="cart-form" name="checkout" class="w-full mt-4 bg-slate-700 hover:bg-slate-800 text-white font-bold py-3.5 px-8 rounded-lg transition-all duration-300 hover:shadow-md">
              {{ 'general.cart.checkout' | t }}
            </button>

            <!-- Update Cart Button -->
            <button type="submit" form="cart-form" class="w-full mt-2 border-2 border-slate-700 text-slate-700 font-semibold py-3 px-8 rounded-lg hover:bg-slate-50 transition">
              {{ 'general.cart.update' | t }}
            </button>

            <!-- Continue Shopping -->
            <a href="{{ routes.all_products_collection_url }}" class="block text-center mt-4 text-sm text-slate-600 hover:text-slate-900 transition underline">
              {{ 'general.cart.continue_shopping' | t }}
            </a>

            <!-- Trust Badges -->
            <div class="mt-6 pt-4 border-t border-slate-200 grid grid-cols-3 gap-2">
              <div class="flex flex-col items-center text-center">
                <svg class="w-6 h-6 text-slate-700 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                <span class="text-[10px] font-semibold text-slate-700 leading-tight">{{ 'products.product.trust_badges.warranty' | t }}</span>
              </div>
              <div class="flex flex-col items-center text-center">
                <svg class="w-6 h-6 text-slate-700 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span class="text-[10px] font-semibold text-slate-700 leading-tight">{{ 'products.product.trust_badges.free_shipping' | t }}</span>
              </div>
              <div class="flex flex-col items-center text-center">
                <svg class="w-6 h-6 text-slate-700 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                <span class="text-[10px] font-semibold text-slate-700 leading-tight">{{ 'products.product.trust_badges.returns' | t }}</span>
              </div>
            </div>
          </div>
        </div>

      </div>

    {%- else -%}

      <!-- Empty Cart State -->
      <div class="flex flex-col items-center justify-center py-16 sm:py-24 text-center">
        <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mb-6">
          <svg class="w-12 h-12 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
          </svg>
        </div>
        <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-2">{{ 'general.cart.empty_title' | t }}</h1>
        <p class="text-slate-500 mb-8 max-w-md">{{ 'general.cart.empty_message' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="border-2 border-slate-700 text-slate-700 font-bold py-3.5 px-8 rounded-lg hover:bg-slate-50 transition">
          {{ 'general.cart.continue_shopping' | t }}
        </a>
      </div>

    {%- endif -%}

  </div>
</section>

{%- if cart.item_count > 0 -%}
<script>
document.addEventListener('DOMContentLoaded', function() {
  var form = document.getElementById('cart-form');
  if (!form) return;

  var qtyButtons = form.querySelectorAll('.qty-btn');
  var removeButtons = form.querySelectorAll('.cart-remove-btn');
  var subtotalEl = document.getElementById('cart-subtotal');

  // Format money using Shopify's locale
  function formatMoney(cents) {
    return new Intl.NumberFormat('{{ request.locale.iso_code }}', {
      style: 'currency',
      currency: '{{ cart.currency.iso_code }}'
    }).format(cents / 100);
  }

  // Update a single line item total
  function updateLineTotal(key, quantity, price) {
    var totalEl = form.querySelector('.line-item-total[data-key="' + key + '"]');
    if (totalEl) totalEl.textContent = formatMoney(price * quantity);
  }

  // Recalculate and update subtotal
  function updateSubtotal(cart) {
    if (subtotalEl) subtotalEl.textContent = formatMoney(cart.total_price);
  }

  // Handle quantity +/- buttons
  qtyButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var key = this.dataset.key;
      var input = form.querySelector('.qty-input[data-key="' + key + '"]');
      if (!input) return;

      var qty = parseInt(input.value, 10) || 0;
      if (this.dataset.action === 'increase') qty++;
      if (this.dataset.action === 'decrease' && qty > 1) qty--;
      input.value = qty;

      // AJAX update
      ShopifyUtils.updateCart(key, qty).then(function(cart) {
        var item = cart.items.find(function(i) { return i.key === key; });
        if (item) updateLineTotal(key, item.quantity, item.price);
        updateSubtotal(cart);
      });
    });
  });

  // Handle remove buttons
  removeButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var key = this.dataset.key;
      var row = this.closest('.cart-item');

      ShopifyUtils.updateCart(key, 0).then(function(cart) {
        if (row) {
          row.style.opacity = '0';
          row.style.transition = 'opacity 0.3s';
          setTimeout(function() {
            row.remove();
            if (cart.item_count === 0) location.reload();
          }, 300);
        }
        updateSubtotal(cart);
      });
    });
  });
});
</script>
{%- endif -%}

{% schema %}
{
  "name": "Cart page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ]
}
{% endschema %}
