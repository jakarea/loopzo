<nav class="main_navigation bg-slate-800" aria-label="Main Navigation">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">

            <!-- Logo -->
            {%- comment -%} <div class="flex-shrink-0">
                <a href="/" class="flex items-center">
                    {%- if section.settings.logo != blank -%}
                        <img class="h-10 w-auto" src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" >
                    {%- else -%}
                        <img class="h-10 w-auto" src="https://cdn.shopify.com/s/files/1/0983/3476/9483/files/loopzo_light_logo.png" alt="{{ shop.name | default: 'Loopzo Logo' }}" >
                    {%- endif -%}
                </a>
            </div>{%- endcomment -%}


            <div class="flex-shrink-0">
  <a href="/" class="flex items-center">
    {%- if section.settings.logo != blank -%}
      {%- comment -%} Using image_tag automatically calculates the correct aspect ratio {%- endcomment -%}
      {{ section.settings.logo | image_url: width: 400 | image_tag: 
        class: 'h-10 w-auto',
        loading: 'eager', 
        preload: true,
        alt: shop.name,
        style: 'background: transparent; color: transparent;'
      }}
    {%- else -%}
      {%- comment -%} Manual fallback for the hardcoded logo {%- endcomment -%}
      <img 
        src="https://cdn.shopify.com/s/files/1/0983/3476/9483/files/loopzo_light_logo.png" 
        class="h-10 w-auto" 
        style="aspect-ratio: auto; background: transparent;"
        alt="Loopzo Logo" 
        loading="eager"
        width="200"
        height="50">
    {%- endif -%}
  </a>
</div>


            <!-- Desktop Menu -->
            <div class="hidden md:flex md:items-center md:space-x-8">
                {%- if section.settings.menu != blank -%}
                    {%- for link in linklists[section.settings.menu].links -%}
                        {%- if link.links != blank -%}
                            <!-- Dropdown Menu Item -->
                            <div class="relative group">
                                <button class="text-white font-bold text-sm hover:text-slate-200 transition flex items-center gap-1.5 py-2">
                                    <span>{{ link.title }}</span>
                                    <svg class="w-3 h-3 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path>
                                    </svg>
                                </button>

                                <!-- Dropdown -->
                                <div class="absolute top-full left-0 w-48 bg-slate-900 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transform -translate-y-2 group-hover:translate-y-0 transition-all duration-300 z-50">
                                    <div class="py-2">
                                        {%- for child_link in link.links -%}
                                            <a href="{{ child_link.url }}" class="block px-4 py-3 text-sm text-gray-300 hover:bg-slate-800 hover:text-white transition">
                                                <div class="flex items-center gap-3">
                                                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                                    </svg>
                                                    <span>{{ child_link.title }}</span>
                                                </div>
                                            </a>
                                        {%- endfor -%}
                                    </div>
                                </div>
                            </div>
                        {%- else -%}
                            <!-- Regular Menu Item -->
                            <a href="{{ link.url }}" class="text-white font-bold text-sm hover:text-slate-200 transition">{{ link.title }}</a>
                        {%- endif -%}
                    {%- endfor -%}
                {%- endif -%}
            </div>

            <!-- Cart Icon (Desktop) -->
            <button onclick="CartDrawer && CartDrawer.open()" class="hidden md:flex text-white hover:text-slate-200 transition p-2 -mr-2" style="position:relative;" aria-label="{{ 'general.cart.title' | t }}">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
                </svg>
                <span class="cart-count-badge" style="position:absolute;top:-4px;right:-4px;min-width:18px;height:18px;display:{% if cart.item_count == 0 %}none{% else %}flex{% endif %};align-items:center;justify-content:center;border-radius:50%;font-size:10px;font-weight:700;background:#ef4444;color:#fff;line-height:1;padding:0 4px;">{{ cart.item_count }}</span>
            </button>

            <!-- Mobile: Cart + Menu Toggle -->
            <div class="md:hidden flex items-center gap-2">
                <button onclick="CartDrawer && CartDrawer.open()" class="text-white hover:text-slate-300 transition p-2" style="position:relative;" aria-label="{{ 'general.cart.title' | t }}">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/>
                    </svg>
                    <span class="cart-count-badge" style="position:absolute;top:-4px;right:-4px;min-width:18px;height:18px;display:{% if cart.item_count == 0 %}none{% else %}flex{% endif %};align-items:center;justify-content:center;border-radius:50%;font-size:10px;font-weight:700;background:#ef4444;color:#fff;line-height:1;padding:0 4px;">{{ cart.item_count }}</span>
                </button>
                <button id="mobile-menu-button" onclick="toggleMenu()" type="button"
                    class="text-white hover:text-slate-300 focus:outline-none" aria-controls="mobile-menu"
                    aria-expanded="false">
                    <span class="sr-only">Open main menu</span>
                    <svg class="h-6 w-6" stroke="currentColor" fill="none" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
            </div>

        </div>
    </div>
</nav>

<!-- Mobile Menu -->
<div id="mobile-menu" class="hidden bg-slate-800 w-full relative z-50">
    <div class="max-w-7xl mx-auto px-2 pt-2 pb-3 space-y-1 sm:px-3">
        {%- if section.settings.menu != blank -%}
            {%- for link in linklists[section.settings.menu].links -%}
                {%- if link.links != blank -%}
                    <!-- Mobile Accordion -->
                    <div class="border-b border-slate-600">
                        <button onclick="toggleMobileMenu('mobile-submenu-{{ forloop.index }}')" class="w-full text-left text-white flex items-center justify-between px-3 py-2 rounded-md text-base font-medium hover:bg-slate-700 transition">
                            <span>{{ link.title }}</span>
                            <svg class="w-4 h-4 text-slate-300 transform transition-transform duration-300" id="mobile-submenu-{{ forloop.index }}-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </button>
                        <div id="mobile-submenu-{{ forloop.index }}" class="hidden bg-slate-900 mt-2 rounded-lg overflow-hidden">
                            {%- for child_link in link.links -%}
                                <a href="{{ child_link.url }}" class="block px-6 py-3 text-gray-300 hover:bg-slate-800 hover:text-white transition">{{ child_link.title }}</a>
                            {%- endfor -%}
                        </div>
                    </div>
                {%- else -%}
                    <!-- Regular Mobile Menu Item -->
                    <a href="{{ link.url }}" class="text-white block px-3 py-2 rounded-md text-base font-medium">{{ link.title }}</a>
                {%- endif -%}
            {%- endfor -%}
        {%- endif -%}
    </div>
</div>

<script src="{{ 'header-navigation.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Main Navigation",
  "class": "main-navigation-section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image",
      "info": "Recommended size: 200x80px. Leave blank to show store name as text."
    },
    {
      "type": "header",
      "content": "Navigation Menu"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu",
      "info": "Select the menu to display. Create menus in Navigation settings."
    }
  ],
  "presets": [
    {
      "name": "Main Navigation"
    }
  ]
}
{% endschema %}
