<section class="product_showcase_section bg-white py-12 sm:py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-5 lg:gap-16">

            <div class="lg:col-span-2 flex flex-col justify-center mb-8 lg:mb-0">
                <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 leading-tight">
                    {%- if section.settings.main_heading != blank -%}
                        {{ section.settings.main_heading }}
                    {%- else -%}
                        Waarom een loopfiets helpt
                    {%- endif -%}
                </h1>

                <div class="mt-4 sm:mt-6 text-sm sm:text-base text-gray-700">
                    {%- if section.settings.description_paragraph_1 != blank -%}
                        {{ section.settings.description_paragraph_1 }}
                    {%- else -%}
                        <p>Een volwassen loopfiets geeft stabiliteit wanneer lopen zwaar of onzeker voelt. Je zit stevig, je benen bewegen in je eigen tempo en je hoeft niet je volledige gewicht te dragen. Zo wordt bewegen rustiger, ontspannen en houd je dagelijkse uitstapjes makkelijker vol.</p>
                    {%- endif -%}
                </div>

                <div class="mt-3 sm:mt-4 text-sm sm:text-base text-gray-700">
                    {%- if section.settings.description_paragraph_2 != blank -%}
                        {{ section.settings.description_paragraph_2 }}
                    {%- else -%}
                        <p>De Loopzo is een compacte fiets zonder trappers, speciaal ontwikkeld voor volwassenen. Je zit comfortabel terwijl de fiets een groot deel van je gewicht draagt. Je benen blijven actief zonder overbelasting, waardoor je vaak langere stukken aflegt dan lopend.</p>
                    {%- endif -%}
                </div>
            </div>

            <div class="lg:col-span-3 mt-8 sm:mt-12 lg:mt-0">
                <div class="grid grid-cols-2 sm:grid-cols-3 grid-rows-2 gap-3 sm:gap-4 auto-rows-fr">

                    <div class="col-span-2 row-span-2 rounded-lg overflow-hidden shadow-lg relative aspect-[3/4] sm:aspect-[4/3]">
                        {%- if section.settings.main_image != blank -%}
                            <img src="{{ section.settings.main_image | image_url: width: 800 }}"
                                srcset="{{ section.settings.main_image | image_url: width: 400 }} 400w,
                                        {{ section.settings.main_image | image_url: width: 800 }} 800w,
                                        {{ section.settings.main_image | image_url: width: 1200 }} 1200w"
                                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 66vw, 40vw"
                                alt="{{ section.settings.main_image.alt | escape }}"
                                class="w-full h-full object-cover object-center"
                                loading="lazy"
                                width="800"
                                height="600">
                        {%- else -%}
                            <img src="https://loopzo.nl/cdn/shop/files/senior-citygen-in-park-with-loopzo.png"
                                alt="Senior with Loopzo in park"
                                class="w-full h-full object-cover object-center"
                                loading="lazy"
                                width="800"
                                height="600">
                        {%- endif -%}
                    </div>

                    <div class="col-span-1 row-span-1 rounded-lg overflow-hidden shadow-lg relative aspect-square">
                        {%- if section.settings.small_image_1 != blank -%}
                            <img src="{{ section.settings.small_image_1 | image_url: width: 400 }}"
                                srcset="{{ section.settings.small_image_1 | image_url: width: 200 }} 200w,
                                        {{ section.settings.small_image_1 | image_url: width: 400 }} 400w,
                                        {{ section.settings.small_image_1 | image_url: width: 600 }} 600w"
                                sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 20vw"
                                alt="{{ section.settings.small_image_1.alt | escape }}"
                                class="w-full h-full object-cover object-center"
                                loading="lazy"
                                width="400"
                                height="400">
                        {%- else -%}
                            <img src="https://loopzo.nl/cdn/shop/files/loopzo-bike.png"
                                alt="Loopzo bike"
                                class="w-full h-full object-cover object-center"
                                loading="lazy"
                                width="400"
                                height="400">
                        {%- endif -%}
                    </div>

                    <div class="col-span-1 row-span-1 rounded-lg overflow-hidden shadow-lg relative aspect-square">
                        {%- if section.settings.small_image_2 != blank -%}
                            <img src="{{ section.settings.small_image_2 | image_url: width: 400 }}"
                                srcset="{{ section.settings.small_image_2 | image_url: width: 200 }} 200w,
                                        {{ section.settings.small_image_2 | image_url: width: 400 }} 400w,
                                        {{ section.settings.small_image_2 | image_url: width: 600 }} 600w"
                                sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 20vw"
                                alt="{{ section.settings.small_image_2.alt | escape }}"
                                class="w-full h-full object-cover object-center"
                                loading="lazy"
                                width="400"
                                height="400">
                        {%- else -%}
                            <img src="https://loopzo.nl/cdn/shop/files/Amped-Balance-Bikes-img.jpg"
                                alt="Balance bikes"
                                class="w-full h-full object-cover object-center"
                                loading="lazy"
                                width="400"
                                height="400">
                        {%- endif -%}
                    </div>

                </div>
            </div>

        </div>
    </div>
</section>

{% schema %}
{
  "name": "Loopzo Product Showcase",
  "tag": "section",
  "class": "section",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "main_heading",
      "label": "Main Heading"
    },
    
    {
      "type": "richtext",
      "id": "description_paragraph_1",
      "label": "First Paragraph"
    },
    {
      "type": "richtext",
      "id": "description_paragraph_2",
      "label": "Second Paragraph"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Large Image",
      "info": "Recommended size: 800x600px"
    },
    {
      "type": "image_picker",
      "id": "small_image_1",
      "label": "Small Image 1",
      "info": "Recommended size: 400x400px"
    },
    {
      "type": "image_picker",
      "id": "small_image_2",
      "label": "Small Image 2",
      "info": "Recommended size: 400x400px"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Loopzo Product Showcase",
      "category": "Loopzo"
    }
  ]
}
{% endschema %}