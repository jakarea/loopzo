<style>
    .footer-link::before {
        content: '';
        position: absolute;
        left: 0;
        bottom: -2px;
        width: 0;
        height: 1px;
        background: linear-gradient(90deg, #94a3b8, #e2e8f0);
        transition: width 0.3s ease;
    }
    .footer-link:hover::before {
        width: 100%;
    }
    .footer-logo img {
        height: 5rem;
        width: auto;
        object-fit: contain;
    }
</style>

<footer class="text-sm">
    <div class="footer_div bg-slate-800 text-gray-200 py-12 sm:py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-12">
                <!-- Logo, Rating and Social -->
                <div class="lg:col-span-4">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center">
                        <div class="flex justify-center md:justify-start">
                            {% if section.settings.footer_logo != blank %}
                            <div class="footer-logo">
                                {{ section.settings.footer_logo | image_url: width: 400 | image_tag: loading: 'eager', sizes: 'auto' }}
                            </div>
                            {% else %}
                            <img
                                class="h-20 w-auto object-contain"
                                src="{{ 'loopzo_light_square_logo.png' | asset_url }}"
                                alt="Loopzo Logo"
                                width="400"
                                height="80">
                            {% endif %}
                        </div>
                        <div class="text-center">
                            {% if section.settings.show_rating %}
                            <div class="flex justify-center text-amber-400 gap-0.5">
                                {% assign rating_value = section.settings.rating_value | default: 5 %}
                                {% assign full_stars = rating_value | floor %}
                                {% assign decimal_part = rating_value | modulo: 1 %}

                                {% comment %} Full stars {% endcomment %}
                                {% for i in (1..full_stars) %}
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19 10 15.27z"></path></svg>
                                {% endfor %}

                                {% comment %} Half star if decimal part >= 0.25 and < 0.75 {% endcomment %}
                                {% if decimal_part >= 0.25 and decimal_part < 0.75 %}
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><defs><linearGradient id="half-gradient-{{ section.id }}"><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="#4B5563" stop-opacity="1"/></linearGradient></defs><path fill="url(#half-gradient-{{ section.id }})" d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19 10 15.27z"></path></svg>
                                {% elsif decimal_part >= 0.75 %}
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19 10 15.27z"></path></svg>
                                {% endif %}

                                {% comment %} Empty stars {% endcomment %}
                                {% assign remaining = 5 | minus: rating_value %}
                                {% if decimal_part >= 0.25 and decimal_part < 0.75 %}
                                    {% assign empty_stars = remaining | floor %}
                                {% elsif decimal_part >= 0.75 %}
                                    {% assign empty_stars = remaining | floor %}
                                {% else %}
                                    {% assign empty_stars = remaining | ceil %}
                                {% endif %}
                                {% for i in (1..empty_stars) %}
                                    <svg class="w-5 h-5 text-gray-600" fill="currentColor" viewBox="0 0 20 20"><path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19 10 15.27z"></path></svg>
                                {% endfor %}
                            </div>
                            {% endif %}
                            {% if section.settings.rating_text != blank %}
                            <p class="text-xs sm:text-sm text-gray-400 mt-2">{{ section.settings.rating_text }}</p>
                            {% endif %}
                            {% if section.settings.reviews_link != blank %}
                            <a href="{{ section.settings.reviews_link }}" target="_blank" rel="noopener" class="text-xs sm:text-sm text-slate-300 font-medium underline hover:text-white">{{ section.settings.reviews_text | default: 'Bekijk reviews' }}</a>
                            {% endif %}
                        </div>
                        <!-- Delivery & Payment Icons -->
                        

                        <div class="payment-delivery-icons flex justify-center md:justify-end items-center flex-wrap gap-y-4 gap-x-2 sm:gap-x-3">
                            <!-- Group 1: Delivery -->
                            <div class="flex items-center gap-2 sm:gap-3">
                                <img src="{{ 'paymetn-icon/Ontwerp_g1.svg' | asset_url }}" alt="GLS" width="50" height="50" loading="lazy" decoding="async" class="w-auto h-auto object-contain" style="max-width:50px; max-height:50px;">
                                <img src="{{ 'paymetn-icon/dhl_g1.svg' | asset_url }}" alt="DHL" width="50" height="50" loading="lazy" decoding="async" class="w-auto h-auto object-contain" style="max-width:50px; max-height:50px;">
                                <img src="{{ 'paymetn-icon/dpd_g1.svg' | asset_url }}" alt="DPD" width="50" height="50" loading="lazy" decoding="async" class="w-auto h-auto object-contain" style="max-width:50px; max-height:50px;">
                                <img src="{{ 'paymetn-icon/postnl_g1.svg' | asset_url }}" alt="PostNL" width="50" height="50" loading="lazy" decoding="async" class="w-auto h-auto object-contain" style="max-width:50px; max-height:50px;">
                            </div>

                            <!-- Spacer -->
                            <div class="w-6 sm:w-10 shrink-0"></div>

                            <!-- Group 2: Payment -->
                            <div class="flex items-center gap-2 sm:gap-3">
                                <img src="{{ 'paymetn-icon/Master_g2.svg' | asset_url }}" alt="Mastercard" width="50" height="50" loading="lazy" decoding="async" class="w-auto h-auto object-contain" style="max-width:50px; max-height:50px;">
                                <img src="{{ 'paymetn-icon/Maestro_g2.svg' | asset_url }}" alt="Maestro" width="50" height="50" loading="lazy" decoding="async" class="w-auto h-auto object-contain" style="max-width:50px; max-height:50px;">
                                <img src="{{ 'paymetn-icon/iDeal_g2.svg' | asset_url }}" alt="iDEAL" width="50" height="50" loading="lazy" decoding="async" class="w-auto h-auto object-contain" style="max-width:50px; max-height:50px;">
                                <img src="{{ 'paymetn-icon/Paypal_g2.svg' | asset_url }}" alt="PayPal" width="50" height="50" loading="lazy" decoding="async" class="w-auto h-auto object-contain" style="max-width:50px; max-height:50px;">
                                <img src="{{ 'paymetn-icon/Bancontact_g2.svg' | asset_url }}" alt="Bancontact" width="50" height="50" loading="lazy" decoding="async" class="w-auto h-auto object-contain" style="max-width:50px; max-height:50px;">
                                <img src="{{ 'paymetn-icon/Apple-pay_g2.svg' | asset_url }}" alt="Apple Pay" width="50" height="50" loading="lazy" decoding="async" class="w-auto h-auto object-contain" style="max-width:50px; max-height:50px;">
                                <img src="{{ 'paymetn-icon/sofort_g2.svg' | asset_url }}" alt="Sofort" width="50" height="50" loading="lazy" decoding="async" class="w-auto h-auto object-contain" style="max-width:50px; max-height:50px;">
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <div class="mt-12 pt-12 border-t border-slate-700 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8">
                <div class="col-span-1 md:col-span-2 lg:col-span-2">
                    <h3 class="text-white font-semibold mb-4 text-base">{{ section.settings.about_text_heading }}</h3>
                    <div class="text-sm text-gray-300 space-y-3 leading-relaxed">
                        {{ section.settings.about_text }}
                    </div>
                </div>
                {% for i in (1..3) %}
                {%- assign menu_handle = 'menu_' | append: i -%}
                {%- assign menu_heading = 'menu_' | append: i | append: '_heading' -%}
                {% if section.settings[menu_handle] != blank %}
                <div>
                    <h3 class="text-white font-semibold mb-4 text-base">{{ section.settings[menu_heading] }}</h3>
                    <ul class="space-y-3">
                        {% for link in linklists[section.settings[menu_handle]].links %}
                        <li><a href="{{ link.url }}" class="footer-link relative inline-block text-sm text-gray-300 transition-all duration-300 hover:text-white hover:pl-1">{{ link.title }}</a></li>
                        {% endfor %}
                    </ul>
                </div>
                {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>

    <!-- Footer Bottom: Copyright, Company Info & Developer Credit -->
    <div class="bg-slate-900 border-t border-slate-700 py-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex flex-col items-center text-center space-y-5">
                <!-- Copyright -->
                <div class="text-gray-300 font-medium text-sm">
                    ©️ 2026 Loopzo Loopfietsen - Alle rechten voorbehouden
                </div>
                
                <!-- Company Details -->
                <div class="flex flex-wrap justify-center items-center gap-x-4 gap-y-2 text-xs text-gray-400">
                    <span class="flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.828 0L6.343 16.657a8 8 0 1111.314 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        Zuidbaan 548H, 2841MD Moordrecht, Nederland
                    </span>
                    <span class="hidden sm:inline text-gray-600">|</span>
                    <span>KVK 85858552</span>
                    <span class="hidden sm:inline text-gray-600">|</span>
                    <span>BTW NL004158990B08</span>
                </div>
                
                <!-- Contact Information -->
                <div class="flex flex-wrap justify-center items-center gap-x-4 gap-y-2 text-xs text-gray-400">
                    <a href="mailto:Info@loopzo.nl" class="flex items-center gap-1.5 hover:text-blue-400 transition-colors">
                        <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                        Info@loopzo.nl
                    </a>
                    <span class="hidden sm:inline text-gray-600">|</span>
                    <a href="tel:0182239021" class="flex items-center gap-1.5 hover:text-blue-400 transition-colors">
                        <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                        </svg>
                        Tel: 085 744 4354
                    </a>
                </div>
            </div>
        </div>
    </div>
</footer>

{% schema %}
{
  "name": "Loopzo Footer",
  "tag": "footer",
  "class": "footer",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Logo Settings"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo"
    },
    {
      "type": "text",
      "id": "logo_alt_text",
      "label": "Logo alt text",
      "default": "Loopzo Logo"
    },
    {
      "type": "header",
      "content": "About Text"
    },
    {
      "type": "text",
      "id": "about_text_heading",
      "label": "About text heading",
      "default": "Over ons"
    },
    {
      "type": "richtext",
      "id": "about_text",
      "label": "About text",
      "default": "<p>Loopzo biedt hoogwaardige loopfietsen voor volwassenen en senioren. Onze fietsen zijn ontworpen voor extra stabiliteit, comfort en bewegingsvrijheid.</p><p>Met aandacht voor detail en Nederlandse vakmanschap garanderen wij kwaliteit en betrouwbaarheid.</p>"
    },
    {
      "type": "header",
      "content": "Menu Column 1"
    },
    {
      "type": "text",
      "id": "menu_1_heading",
      "label": "Heading",
      "default": "Pagina's"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu",
      "info": "Select a menu (e.g., Pagina's, Over Ons, Contact)"
    },
    {
      "type": "header",
      "content": "Menu Column 2"
    },
    {
      "type": "text",
      "id": "menu_2_heading",
      "label": "Heading",
      "default": "Klantenservice"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Menu Column 3"
    },
    {
      "type": "text",
      "id": "menu_3_heading",
      "label": "Heading",
      "default": "Bedrijf"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Rating Settings"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating stars",
      "default": true
    },
    {
      "type": "range",
      "id": "rating_value",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "unit": "★",
      "label": "Rating value",
      "default": 5
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating text",
      "default": "Gebaseerd op 25+ reviews"
    },
    {
      "type": "header",
      "content": "Reviews Link"
    },
    {
      "type": "url",
      "id": "reviews_link",
      "label": "Reviews URL",
      "info": "Link to your reviews page"
    },
    {
      "type": "text",
      "id": "reviews_text",
      "label": "Reviews link text",
      "default": "Bekijk reviews"
    }
  ],
  "presets": [
    {
      "name": "Loopzo Footer",
      "category": "Loopzo"
    }
  ]
}
{% endschema %}