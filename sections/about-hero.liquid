<!-- About Hero Section -->
<section class="relative bg-gradient-to-br from-slate-700 to-slate-800 py-16 sm:py-20 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-4xl mx-auto">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
        {{ section.settings.heading }}
      </h1>
      <p class="text-lg sm:text-xl text-slate-200 leading-relaxed">
        {{ section.settings.subheading }}
      </p>
    </div>
  </div>

  <!-- Decorative Wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg class="w-full h-12 sm:h-16 text-white" preserveAspectRatio="none" viewBox="0 0 1440 54" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 22L60 25.3C120 28.7 240 35.3 360 37.8C480 40.3 600 38.7 720 35.3C840 32 960 26.7 1080 23.5C1200 20.3 1320 19.3 1380 18.8L1440 18.3V54H1380C1320 54 1200 54 1080 54C960 54 840 54 720 54C600 54 480 54 360 54C240 54 120 54 60 54H0V22Z" fill="currentColor" />
    </svg>
  </div>
</section>

{% schema %}
{
  "name": "About Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Maak kennis met Loopzo"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Bij Loopzo draait alles om beweging, comfort en vertrouwen"
    }
  ],
  "presets": [
    {
      "name": "About Hero"
    }
  ]
}
{% endschema %}
