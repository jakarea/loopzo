<!-- ============= History Section ============= -->
<section class="history_section bg-white py-12 sm:py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

       
        <!-- Main Heading -->
        <div class="text-center mb-10 sm:mb-12">
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4">
                Maak kennis met <span class="text-slate-700">Loopzo</span>
            </h1>
            <div class="max-w-4xl mx-auto">
                <p class="text-base sm:text-lg text-slate-600 leading-relaxed">
                    Bij Loopzo draait alles om beweging, comfort en vertrouwen. Vanuit onze vestiging in Moordrecht ontwikkelen we
                    loopfietsen voor volwassenen die ontworpen zijn om dagelijks, veilig en met plezier te gebruiken.
                </p>
            </div>
        </div>

        <!-- Hero Image with Feature Icons Grid -->
        <div class="mb-12 sm:mb-16">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">

                <!-- Main Image -->
                <div class="lg:col-span-7">
                    <div class="rounded-2xl overflow-hidden shadow-xl">
                        <img src="{{ 'design-loopzo-bike.png' | asset_url }}"
                            alt="Loopzo ontwerp en ontwikkeling - Nederlands design uit Moordrecht"
                            class="w-full h-auto object-cover" loading="lazy">
                    </div>
                </div>

                <!-- Feature Icons -->
                <div class="lg:col-span-5">
                    <div class="grid grid-cols-1 gap-4">

                        <!-- Feature 1 -->
                        <div class="flex items-start gap-4 bg-slate-50 p-4 rounded-xl hover:bg-slate-100 hover:shadow-md transition-all duration-300">
                            <div class="flex-shrink-0">
                                <div class="bg-slate-700 p-2.5 rounded-lg">
                                    <img src="{{ '1idea.png' | asset_url }}" alt="Nederlands Ontwerp" class="w-10 h-10 sm:w-12 sm:h-12 object-contain" style="filter: brightness(0) invert(1);">
                                </div>
                            </div>
                            <div>
                                <h3 class="text-base sm:text-lg font-bold text-slate-900 mb-0.5">Nederlands Ontwerp</h3>
                                <p class="text-sm text-slate-600">Ontwikkeld en getest in Moordrecht</p>
                            </div>
                        </div>

                        <!-- Feature 2 -->
                        <div class="flex items-start gap-4 bg-slate-50 p-4 rounded-xl hover:bg-slate-100 hover:shadow-md transition-all duration-300">
                            <div class="flex-shrink-0">
                                <div class="bg-slate-700 p-2.5 rounded-lg">
                                    <img src="{{ '2frame.png' | asset_url }}" alt="10 jaar frame garantie" class="w-10 h-10 sm:w-12 sm:h-12 object-contain" style="filter: brightness(0) invert(1);">
                                </div>
                            </div>
                            <div>
                                <h3 class="text-base sm:text-lg font-bold text-slate-900 mb-0.5">10 jaar frame garantie</h3>
                                <p class="text-sm text-slate-600">Kwaliteit waar je op kunt vertrouwen</p>
                            </div>
                        </div>

                        <!-- Feature 3 -->
                        <div class="flex items-start gap-4 bg-slate-50 p-4 rounded-xl hover:bg-slate-100 hover:shadow-md transition-all duration-300">
                            <div class="flex-shrink-0">
                                <div class="bg-slate-700 p-2.5 rounded-lg">
                                    <img src="{{ '3chain.png' | asset_url }}" alt="Comfort en stabiliteit" class="w-10 h-10 sm:w-12 sm:h-12 object-contain" style="filter: brightness(0) invert(1);">
                                </div>
                            </div>
                            <div>
                                <h3 class="text-base sm:text-lg font-bold text-slate-900 mb-0.5">Comfort en stabiliteit</h3>
                                <p class="text-sm text-slate-600">Gemaakt voor dagelijks gebruik</p>
                            </div>
                        </div>

                        <!-- Feature 4 -->
                        <div class="flex items-start gap-4 bg-slate-50 p-4 rounded-xl hover:bg-slate-100 hover:shadow-md transition-all duration-300">
                            <div class="flex-shrink-0">
                                <div class="bg-slate-700 p-2.5 rounded-lg">
                                    <img src="{{ '4support.png' | asset_url }}" alt="Persoonlijk contact" class="w-10 h-10 sm:w-12 sm:h-12 object-contain" style="filter: brightness(0) invert(1);">
                                </div>
                            </div>
                            <div>
                                <h3 class="text-base sm:text-lg font-bold text-slate-900 mb-0.5">Persoonlijk contact</h3>
                                <p class="text-sm text-slate-600">We denken met je mee, zonder haast</p>
                            </div>
                        </div>

                        <!-- Feature 5 -->
                        <div class="flex items-start gap-4 bg-slate-50 p-4 rounded-xl hover:bg-slate-100 hover:shadow-md transition-all duration-300">
                            <div class="flex-shrink-0">
                                <div class="bg-slate-700 p-2.5 rounded-lg">
                                    <img src="{{ '5repairing-service.png' | asset_url }}" alt="Service na aankoop" class="w-10 h-10 sm:w-12 sm:h-12 object-contain" style="filter: brightness(0) invert(1);">
                                </div>
                            </div>
                            <div>
                                <h3 class="text-base sm:text-lg font-bold text-slate-900 mb-0.5">Service na aankoop</h3>
                                <p class="text-sm text-slate-600">Onderdelen en onderhoud eenvoudig geregeld</p>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>

        <!-- Innovation Story Section -->
        <div class="mb-12 sm:mb-16">
            <div class="max-w-4xl mx-auto text-center mb-8">
                <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-slate-900 mb-4">
                    Van idee tot beweging
                </h2>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 max-w-6xl mx-auto">

                <!-- Story Column 1 -->
                <div class="space-y-4">
                    <p class="text-sm sm:text-base text-slate-700 leading-relaxed">
                        Bij Loopzo geloven we dat mobiliteit de basis is van vrijheid. Het idee voor onze loopfiets ontstond vanuit een
                        simpel uitgangspunt: volwassenen een betrouwbaar hulpmiddel bieden om actief te blijven, zonder gedoe en zonder druk.
                        Een Loopzo moet ondersteunen, niet in de weg zitten.
                    </p>
                    <p class="text-sm sm:text-base text-slate-700 leading-relaxed">
                        We richten ons op wat echt telt: stabiliteit, kwaliteit en veiligheid. Geen overbodige techniek, maar een stevige
                        loopfiets die jarenlang meegaat en dagelijks gebruikt kan worden. De Loopzo geeft vertrouwen, helpt bij balans en
                        maakt bewegen weer meer vanzelfsprekend.
                    </p>
                </div>

                <!-- Story Column 2 -->
                <div class="space-y-4">
                    <p class="text-sm sm:text-base text-slate-700 leading-relaxed">
                        Een loopfiets voor volwassenen is een laagdrempelige manier om conditie en mobiliteit te behouden of te verbeteren.
                        Het risico op ongelukken is klein, omdat de loopfiets op de stoep gebruikt mag worden. Dit maakt de Loopzo geschikt
                        voor mensen die zekerheid willen, maar wél in beweging willen blijven. Ook in revalidatie en zorginstellingen wordt
                        de loopfiets steeds vaker ingezet door de natuurlijke manier van voortbewegen.
                    </p>
                    <p class="text-sm sm:text-base text-slate-700 leading-relaxed">
                        Voor veel gebruikers voelt de Loopzo in het begin misschien even anders. Maar wie het probeert, merkt al snel hoe
                        logisch het is. De beweging is natuurlijk, de houding is recht en het gevoel van controle is groot. En vaak ontstaat
                        er iets anders namelijk: <strong class="font-semibold text-slate-900">plezier!</strong>
                    </p>
                </div>

            </div>
        </div>

        <!-- CTA Section -->
        <div class="bg-slate-800 rounded-2xl p-8 sm:p-10 text-center shadow-xl">
            <p class="text-lg sm:text-xl text-white font-medium mb-6 leading-relaxed max-w-3xl mx-auto">
                Ontdek onze loopfietsen en accessoires en vind de Loopzo die bij jou past.
            </p>
            <a href="{{ routes.collections_url }}"
                class="inline-flex items-center bg-white text-slate-900 px-8 py-3 rounded-lg font-semibold text-base hover:bg-slate-100 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 group">
                Bekijk het assortiment
                <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform duration-300"
                    fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
            </a>
        </div>

    </div>
</section>

